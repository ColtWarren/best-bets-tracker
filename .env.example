# ===========================================
# Best Bets Tracker - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=best_bets_tracker
DB_USERNAME=root
DB_PASSWORD=your_db_password_here

# Server
SERVER_PORT=8081

# Main App (source of best bets API)
MAIN_APP_BASE_URL=http://localhost:8080

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081

# ===========================================
# API Keys (active — wired into application.properties)
# ===========================================

# Claude AI - for AI-powered accuracy insights
CLAUDE_API_KEY=your_claude_api_key_here

# The Odds API - for fetching closing lines and odds data
ODDS_API_KEY=your_odds_api_key_here

# ESPN API - no key required (public API)

# Internal API key — must match the main app's INTERNAL_API_KEY
# Used for automated machine-to-machine calls to fetch best bets
INTERNAL_API_KEY=your_shared_internal_api_key_here

# ===========================================
# API Keys (reserved for future use)
# ===========================================

# OpenWeatherMap - weather impact on bet outcomes
# OPENWEATHERMAP_API_KEY=your_openweathermap_key_here

# Weather API - legacy weather service
# WEATHER_API_KEY=your_weather_api_key_here

# API-Football - soccer fixtures and stats
# APIFOOTBALL_API_KEY=your_apifootball_key_here

# College Basketball Data - CBB team stats and ratings
# CBB_API_KEY=your_cbb_api_key_here

# College Football Data - CFB team stats and ratings
# CFB_API_KEY=your_cfb_api_key_here

# BallDontLie - WNBA team stats
# BALLDONTLIE_API_KEY=your_balldontlie_key_here

# Google OAuth2 - authentication
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here
